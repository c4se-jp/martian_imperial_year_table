{
  "name": "martian_imperial_year_table",
  "private": true,
  "description": "帝國火星曆",
  "license": "Unlicense",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w imperial_calendar build && npm run -w calendar_svg build && npm run -w martian_api build && npm run -w martian_ui build && npm run -w martian_widget_ui build",
    "lint": "npm run --workspaces lint",
    "test": "npm run --workspaces test",
    "test:gha": "yamllint .github/workflows/ && actionlint && ghalint run && zizmor .",
    "format": "oxfmt packages/"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.54.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
