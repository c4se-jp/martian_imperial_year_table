{
  "name": "martian_ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run generate:docs",
    "build": "npm run build:web",
    "build:web": "vite build --outDir ../../dist --emptyOutDir true",
    "generate:api-doc": "node ./scripts/generate-api-doc.mjs",
    "generate:docs": "npm run generate:api-doc && npm run generate:mcp-doc",
    "generate:mcp-doc": "node ./scripts/generate-mcp-doc.mjs",
    "lint": "echo \"No linting configured\"",
    "preview": "vite preview",
    "prestart:dev": "npm run generate:docs",
    "start:dev": "vite",
    "test": "vitest --run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-web": "^0.58.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@opentelemetry/sdk-trace-web": "^2.6.0",
    "bulma": "^1.0.4",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  }
}
